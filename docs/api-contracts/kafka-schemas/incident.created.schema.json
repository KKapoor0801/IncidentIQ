{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "incident.created.schema.json",
  "title": "IncidentCreatedEvent",
  "description": "Published to incident.created when a new incident is reported.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "incidentId",
    "title",
    "description",
    "reporterId",
    "createdAt",
    "schemaVersion"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "const": "INCIDENT_CREATED"
    },
    "incidentId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the created incident."
    },
    "title": {
      "type": "string",
      "description": "Incident title."
    },
    "description": {
      "type": "string",
      "description": "Incident description."
    },
    "reporterId": {
      "type": "string",
      "format": "uuid",
      "description": "User who reported the incident."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of creation."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Payload schema version.",
      "examples": ["1.0"]
    },
    "traceId": {
      "type": "string",
      "description": "Distributed trace identifier propagated from the originating HTTP request. Optional for backward compatibility."
    }
  },
  "additionalProperties": false
}
