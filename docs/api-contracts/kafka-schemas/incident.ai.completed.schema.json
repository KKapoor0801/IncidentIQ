{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "incident.ai.completed.schema.json",
  "title": "IncidentAiCompletedEvent",
  "description": "Published to incident.ai.completed after the AI service finishes classification.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "incidentId",
    "category",
    "priority",
    "confidenceScore",
    "modelUsed",
    "completedAt",
    "schemaVersion"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "const": "INCIDENT_AI_COMPLETED"
    },
    "incidentId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the classified incident."
    },
    "category": {
      "type": ["string", "null"],
      "description": "AI-assigned incident category."
    },
    "priority": {
      "type": ["string", "null"],
      "description": "AI-assigned incident priority (e.g. P1, P2, P3, P4)."
    },
    "confidenceScore": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1,
      "description": "Model confidence score between 0 and 1."
    },
    "modelUsed": {
      "type": "string",
      "description": "Ollama model identifier used for classification.",
      "examples": ["llama3.1:8b"]
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of classification completion."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Payload schema version.",
      "examples": ["1.0"]
    },
    "traceId": {
      "type": "string",
      "description": "Distributed trace identifier propagated from the originating HTTP request. Optional for backward compatibility."
    }
  },
  "additionalProperties": false
}
