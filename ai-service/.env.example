# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Spring Boot core service (callback target)
CORE_SERVICE_URL=http://localhost:8080

# Ollama LLM runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=30000

# Elasticsearch
ES_URIS=http://localhost:9200

# Internal service token (must match Spring Boot's AI_SERVICE_TOKEN)
AI_SERVICE_TOKEN=dev-internal-service-token

# Logging
LOG_LEVEL=INFO
