# PostgreSQL
DB_PASSWORD=changeme

# JWT signing secrets (min 256-bit / 32 chars for HS256)
JWT_ACCESS_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-a-different-secure-random-string-32-chars

# Internal service-to-service token (FastAPI -> Spring Boot callback)
AI_SERVICE_TOKEN=change-this-internal-service-token
